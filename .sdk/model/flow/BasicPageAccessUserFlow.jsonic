# BasicPageAccessUserFlow

main: kit: flow: BasicPageAccessUserFlow:
{
  entity: "page_access_user",
  kind: "basic",
  name: "BasicPageAccessUserFlow",
  step: [
    {
      input: {
        ref: "page_access_user_ref01"
      }

      match: {
        page_id: "page01"
      }

      op: "create"
    }

    {
      match: {
        page_id: "page01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "page_access_user_ref01"
          }
        }
      ]
    }

    {
      data: {
        page_id: "page01"
      }

      input: {
        ref: "page_access_user_ref01",
        srcdatavar: "page_access_user_ref01_data",
        suffix: "_up0",
        textfield: "created_at"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-page_access_user_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "page_access_user_ref01",
        srcdatavar: "page_access_user_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "page_access_user01",
        page_id: "page01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-page_access_user_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "page_access_user_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "page_access_user01",
        page_id: "page01"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      match: {
        page_id: "page01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "page_access_user_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPageAccessUserFlow"
}